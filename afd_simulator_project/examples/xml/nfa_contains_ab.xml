<automaton type="nfa">
  <alphabet>
    <symbol>a</symbol>
    <symbol>b</symbol>
  </alphabet>
  <states>
    <state name="q0" initial="true" accept="false" x="100" y="180" />
    <state name="q1" initial="false" accept="false" x="300" y="100" />
    <state name="q2" initial="false" accept="true" x="500" y="180" />
  </states>
  <transitions>
    <transition from="q0" symbol="a" to="q0" />
    <transition from="q0" symbol="a" to="q1" />
    <transition from="q0" symbol="b" to="q0" />
    <transition from="q1" symbol="b" to="q2" />
    <transition from="q2" symbol="a" to="q2" />
    <transition from="q2" symbol="b" to="q2" />
  </transitions>
</automaton>